# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/support_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# JWT — use any 32+ character string for local dev
JWT_SECRET=your-32-plus-character-secret-key-here
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Grafana (production only — local uses admin/admin default)
GRAFANA_ADMIN_PASSWORD=admin

# Docker Compose prod (your GitHub username)
GITHUB_REPOSITORY_OWNER=your-github-username
