{
  "uid": "support-platform-overview",
  "title": "AI Support Platform Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ticket Creation Rate",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(tickets_created_total[5m])"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "AI Processing Success Rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(ai_processing_total{success=\"true\"}[5m]) / rate(ai_processing_total[5m])"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Avg AI Processing Duration (seconds)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(ai_processing_duration_seconds_sum[5m]) / rate(ai_processing_duration_seconds_count[5m])"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg AI Confidence Score",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "avg(ai_confidence_score_sum / ai_confidence_score_count)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (uri, method)(rate(http_server_requests_seconds_count[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Error Rate (5xx)",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Memory Used",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (application)"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Active Database Connections",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(hikaricp_connections_active) by (application)"
        }
      ]
    }
  ]
}
